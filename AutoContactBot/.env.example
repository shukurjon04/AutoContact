# ==============================================================================
# DOMAIN & SSL (Nginx auto-provisioning — faqat shu 2 joyni to'ldiring)
# ==============================================================================
DOMAIN=yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com

# ==============================================================================
# TELEGRAM BOT
# ==============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_IDS=123456789,987654321   # comma-separated admin Telegram IDs

# ==============================================================================
# DJANGO
# ==============================================================================
SECRET_KEY=your-very-secret-django-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com  # DOMAIN bilan bir xil bo'lishi kerak
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com  # HTTPS format
DJANGO_SETTINGS_MODULE=config.settings.production

# ==============================================================================
# DATABASE (PostgreSQL)
# ==============================================================================
DB_NAME=subscription_bot_db
DB_USER=subscription_bot_user
DB_PASSWORD=strong_password_here
DB_HOST=postgres
DB_PORT=5432

# ==============================================================================
# REDIS & CELERY
# ==============================================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ==============================================================================
# PAYME
# ==============================================================================
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_SECRET_KEY=your_payme_secret_key
PAYME_TEST_SECRET_KEY=your_payme_test_secret_key
PAYME_TEST_MODE=False
# Payme allowed IPs (comma-separated)
PAYME_ALLOWED_IPS=185.8.212.184,185.8.212.185,185.8.212.186

# ==============================================================================
# WEBHOOK
# ==============================================================================
WEBHOOK_HOST=https://yourdomain.com               # https://DOMAIN formatda
WEBHOOK_PATH=/bot/webhook
WEBHOOK_SECRET_TOKEN=your_webhook_secret_token

# ==============================================================================
# ADMIN PANEL
# ==============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong_admin_password_here

# ==============================================================================
# CORS & SECURITY
# ==============================================================================
CORS_ALLOWED_ORIGINS=https://yourdomain.com        # https://DOMAIN formatda
